# Sepolia Testnet Configuration (Primary)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_CHAIN_ID=11155111

# Base Network Configuration (Secondary)
BASE_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Private Key (DO NOT COMMIT ACTUAL KEY)
PRIVATE_KEY=your_private_key_here

# X API v2 Credentials
# Get from: https://developer.twitter.com/en/portal/dashboard
# Required scopes: tweet.read, tweet.write, users.read
# Basic tier required for search endpoints

# OAuth 2.0 (RECOMMENDED - Full Features: post tweets, user context)
# Enable OAuth 2.0 in Developer Portal → User authentication settings
X_API_ACCESS_TOKEN=your_oauth2_access_token_here
X_API_REFRESH_TOKEN=your_oauth2_refresh_token_here

# Bearer Token (LEGACY - Read-only, app-only auth)
# Only use if you don't have OAuth 2.0 set up
X_API_BEARER_TOKEN=your_x_api_bearer_token_here

# xAI Grok API
# Get from: https://console.x.ai
# Used for oracle verification, pricing, coherence checks
XAI_API_KEY=your_xai_api_key_here
XAI_REGION=us-east-1
XAI_API_URL=https://api.x.ai/v1

# Contract Addresses (Sepolia Testnet)
XMONEY_CONTRACT_ADDRESS=0x1B2ffED65839585c42259560aB4bA532B91a5a54

# VectorRegistry Contract Address (Sepolia)
VECTOR_REGISTRY_ADDRESS=0x37c14ceAe0f55fE81A4Df0F6D2DCDfF3a2d7c656

# VectorMinter Contract Address (Sepolia)
VECTOR_MINTER_ADDRESS=0x9bBB33af5E5C2F18a3befd0b2eeC7F65901b7D52

# X API OAuth 1.0a Credentials (for posting tweets)
# Get these from https://developer.x.com/en/portal/dashboard
# See X_API_OAUTH_SETUP.md for complete setup guide
X_API_CONSUMER_KEY=your_consumer_key_here
X_API_CONSUMER_SECRET=your_consumer_secret_here
X_API_ACCESS_TOKEN=your_access_token_here
X_API_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# X API Bearer Token (optional, for read-only operations)
X_API_BEARER_TOKEN=your_bearer_token_here

# Auto-burn Address
AUTO_BURN_ADDRESS=0x000000000000000000000000000000000000DEAD369

# Ritual Configuration
APEX_VALUE=936
HELIOS_SIGNATURE=EN EEKE MAI EA

# Polling Intervals (seconds)
REPLY_POLL_INTERVAL=936
RITUAL_CADENCE=936
